menu "Storage"

config DOOR_LOCK_ALIRO_PSA_KEY_ID_RANGE_BASE
	hex "PSA key ID range base"
	default 0x40000
	help
	  Start of the PSA key ID range reserved for Aliro keys.
	  All Aliro key IDs are derived as offsets from this base value.

config DOOR_LOCK_ALIRO_PSA_PROTECTED_STORAGE_UID_BASE
	hex "PSA Protected Storage UID base"
	default 0x500000000
	help
	  Base PSA Protected Storage UID used by Aliro reader data objects.
	  Per-object UIDs are derived from this base using fixed offsets.

config DOOR_LOCK_STORAGE_MAX_STORED_ACCESS_DOCUMENTS
    int "Maximum number of stored Access Documents"
    default 0 if SOC_SERIES_NRF52X
    default 5 if DOOR_LOCK_STEP_UP_PHASE
    default 0
    help
      Specifies the maximum number of Access Documents that can be
      stored. This determines the size of the statically allocated array
      for Access Document storage.

config DOOR_LOCK_STORAGE_MAX_STORED_ACCESS_DOCUMENT_SIZE
    int "Maximum size of the stored Access Document"
    default 55 if DOOR_LOCK_STEP_UP_PHASE
    default 0
    help
      Specifies the maximum size of the stored Access Document.

endmenu # Storage
