rsource "Kconfig.rfal.defconfig"

config RFAL_RX_TIMEOUT_MS
	int "RFAL RX timeout in ms"
	default 500

config RFAL_IDLE_TIMEOUT_MS
	int "RFAL idle timeout in ms"
	default 500

# Prompt-less option only for internal tuning of the RFAL worker thread. Do not change it.
config RFAL_NFC_WORKER_TIMEOUT_MS
	int
	default 30

module = NCS_ALIRO_RFAL
module-str = ALIRO_RFAL
module-dep = LOG
module-help = Enables Aliro NFC RFAL log messages.
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"
