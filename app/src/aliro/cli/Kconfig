if DOOR_LOCK_CLI

config DOOR_LOCK_CLI_PROVISIONING
	bool
	default y if !CHIP || DOOR_LOCK_CREDENTIAL_ISSUER_CA

config DOOR_LOCK_CLI_READER
	bool
	default y if !CHIP || DOOR_LOCK_READER_CERTIFICATE

config SHELL_CMD_BUFF_SIZE
	# Shell buffer must fit: "dl reader certificate set " (26 chars) + hex string (2 * cert size)
	# For 512 byte cert: 26 + 1024 = 1050
	default 1052 if (SHELL && DOOR_LOCK_READER_CERTIFICATE)

endif # DOOR_LOCK_CLI
