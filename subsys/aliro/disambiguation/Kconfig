menuconfig DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION
	bool "UWB front/back disambiguation [EXPERIMENTAL]"
	depends on DOOR_LOCK_ALIRO_UWB
	depends on QM35_UWB_ALIRO_ZEPHYR
	select Q_ALIRO_DISAMBIGUATION
	select EXPERIMENTAL
	help
	  Enable the front/back disambiguation algorithm (CIR, distance, and PDOA processing).

if DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_MAX_CIR
	int "Max CIR threshold for disambiguation"
	default 800
	range 100 5000
	help
	  Maximum absolute CIR value. When the radar CIR exceeds this threshold,
	  the algorithm reuses the previous FRONT/BACK decision instead of
	  computing p_ratio. Increase if genuine detections are being skipped.

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_P_RATIO
	int "p_ratio threshold for disambiguation"
	default 7500 if DOOR_LOCK_ALIRO_UWB_QM35_ANTENNA_4PORT
	default 6000 if DOOR_LOCK_ALIRO_UWB_QM35_ANTENNA_2PORT
	default 7500
	range 1 30000
	help
	  Minimum p_ratio for FRONT detection. The value is multiplied by 10000
	  (e.g. set 6000 for 0.6). p_ratio is derived from radar CIR amplitude
	  and phone RSSI. Lower values increase FRONT detection range but reduce
	  accuracy.

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_NB_BLOCKS
	int "Max noise blocks threshold for disambiguation"
	default 10
	range 0 40
	help
	  Maximum number of noise blocks allowed for a FRONT decision.
	  Higher values are more permissive (easier FRONT detection).

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_NOISE_THRESHOLD
	int "Noise block amplitude threshold"
	default 15
	range 1 100
	help
	  CIR amplitude below which a block is classified as noise (normal angle).

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_SHADOW_THRESHOLD
	int "Shadow noise block amplitude threshold"
	default 8
	range 1 100
	help
	  CIR amplitude below which a block is classified as noise in the shadow region (back side).

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_BLIND_DISTANCE_CM
	int "Blind distance (cm) below which disambiguation is disabled"
	default 30
	range 0 100
	help
	  Minimum distance for the algorithm to engage. Below this value the
	  result is unreliable (too close to the antenna).

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_SECURE_BUBBLE_CM
	int "Secure bubble radius (cm) for door open confirmation"
	default 150
	range 10 200
	help
	  Door open is confirmed only when the user is within this distance.
	  Acts as a final gate after FRONT is detected.

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_FRONT_TO_BACK_CONFIRM
	int "Consecutive BACK ticks required for FRONT to BACK transition"
	default 8
	range 1 20
	help
	  Number of consecutive BACK results required to switch the side
	  decision from FRONT to BACK. Acts as a low-pass filter to prevent
	  spurious BACK flashes (e.g. caused by CIR saturation or transient
	  noise). Higher values make the FRONT state more stable.

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_BACK_TO_FRONT_CONFIRM
	int "Consecutive FRONT ticks required for BACK to FRONT transition"
	default 6
	range 1 20
	help
	  Number of consecutive FRONT results required to switch the side
	  decision from BACK to FRONT. Acts as a low-pass filter to prevent
	  spurious FRONT detections. Lower values make FRONT detection faster.

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_PDOA_OFFSET_DEG
	int "PDOA calibration offset (degrees)"
	default 0
	range -180 180
	help
	  PDOA offset in degrees subtracted from raw PDOA before feeding the
	  disambiguation algorithm. Compensates for antenna placement.

config DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION_DISTANCE_OFFSET_CM
	int "Distance calibration offset (cm)"
	default 0
	range -200 200
	help
	  Distance offset in cm subtracted from raw UWB range measurements
	  before feeding the disambiguation algorithm. Compensates for
	  systematic ranging bias.

module = DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION
module-str = "UWB disambiguation"
module-dep = LOG
source "$(ZEPHYR_BASE)/subsys/logging/Kconfig.template.log_config"

endif # DOOR_LOCK_ALIRO_UWB_DISAMBIGUATION
