menuconfig DOOR_LOCK_MATTER_ACCESS
	bool "Matter Access Storage"
	depends on CHIP
	help
	  Enable Matter Access Storage.

if DOOR_LOCK_MATTER_ACCESS

module = DOOR_LOCK_MATTER_ACCESS
module-str = Door Lock Matter Access Storage
source "$(ZEPHYR_BASE)/subsys/logging/Kconfig.template.log_config"

config DOOR_LOCK_MATTER_ACCESS_MAX_NUM_USERS
	int "Maximum number of users supported by the lock"
	default 10

config DOOR_LOCK_MATTER_ACCESS_MAX_NUM_CREDENTIALS_PER_USER
	int "Maximum total number of credentials per one user supported by the lock"
	default 4

config DOOR_LOCK_MATTER_ACCESS_MAX_NUM_CREDENTIALS_PER_TYPE
	int "Maximum number of credentials of given type supported by the lock"
	default 15

config DOOR_LOCK_MATTER_ACCESS_MAX_CREDENTIAL_LENGTH
	int "Maximum length of the single credential supported by the lock"
	default 10

config DOOR_LOCK_MATTER_ACCESS_CREDENTIAL_TYPES_PIN
	bool "Support for PIN credentials"

config DOOR_LOCK_MATTER_ACCESS_CREDENTIAL_TYPES_RFID
	bool "Support for RFID credentials"

config DOOR_LOCK_MATTER_ACCESS_CREDENTIAL_TYPES_FINGER
	bool "Support for Fingerprint credentials"

config DOOR_LOCK_MATTER_ACCESS_CREDENTIAL_TYPES_VEIN
	bool "Support for FingerVein credentials"

config DOOR_LOCK_MATTER_ACCESS_CREDENTIAL_TYPES_FACE
	bool "Support for Face credentials"

config DOOR_LOCK_MATTER_ACCESS_CREDENTIAL_TYPES_ALIRO
	bool "Support for Aliro credentials"

config DOOR_LOCK_MATTER_ACCESS_SCHEDULES
	bool "Support for WeekDay, YearDay and Holiday schedules in lock"
	help
	  This option adds support for an optional Timed Schedule Access Lock feature.
	  You can use Week Day, Year Day and Holiday schedules to restrict access for a
	  specific user for a defined time window. For example, use it to
	  give the user access only for three days in week.

if DOOR_LOCK_MATTER_ACCESS_SCHEDULES

config DOOR_LOCK_MATTER_ACCESS_SCHEDULES_MAX_WEEKDAY_SCHEDULES_PER_USER
	int "Maximum number of WeekDay schedules per one user supported by the lock"
	default 5

config DOOR_LOCK_MATTER_ACCESS_SCHEDULES_MAX_YEARDAY_SCHEDULES_PER_USER
	int "Maximum number of YearDay schedules per one user supported by the lock"
	default 5

config DOOR_LOCK_MATTER_ACCESS_SCHEDULES_MAX_HOLIDAY_SCHEDULES
	int "Maximum number of Holiday schedules supported by the lock"
	default 5

endif # DOOR_LOCK_MATTER_ACCESS_SCHEDULES

config DOOR_LOCK_MATTER_ACCESS_DEBUG
	bool "Debug features to print users and credentials"
	help
	  Debug features allow for checking and printing current users, their state, and
	  associated credentials.

config DOOR_LOCK_MATTER_ACCESS_PRINT_STORAGE_STATUS
	bool "Print storage status after each store call"
	# This feature assumes that items are eventually stored in Zephyr settings subsystem
	depends on TRUSTED_STORAGE_STORAGE_BACKEND_SETTINGS
	help
	  Debug feature to print the debug-level log that contains information of the entry being stored
	  to persistent storage and how many bytes are left to store the new entry. It can be used to verify
	  whether credential, schedule or user entries are written properly to persistent storage.
	  This option should be disabled in production firmware
	  version.

choice DOOR_LOCK_MATTER_ACCESS_STORAGE_CHOICE
	prompt "Access storage implementation"
	default DOOR_LOCK_MATTER_ACCESS_STORAGE_PROTECTED_STORAGE

config DOOR_LOCK_MATTER_ACCESS_STORAGE_PROTECTED_STORAGE
	bool "PSA Protected Storage"
	# PSA SSF Crypto Client is not ready for PSA PS backend
	depends on !CHIP_WIFI && !PSA_SSF_CRYPTO_CLIENT
	# When building with TF-M, Protected Storage is enabled by default
	select TRUSTED_STORAGE if !BUILD_WITH_TFM
	select PSA_PROTECTED_STORAGE if !BUILD_WITH_TFM

endchoice

if DOOR_LOCK_MATTER_ACCESS_STORAGE_PROTECTED_STORAGE

config DOOR_LOCK_MATTER_ACCESS_STORAGE_PROTECTED_STORAGE_UID_OFFSET
	int "Access storage PSA Protected Storage UID range start"
	default 0

endif # DOOR_LOCK_MATTER_ACCESS_STORAGE_PROTECTED_STORAGE

endif # DOOR_LOCK_MATTER_ACCESS
