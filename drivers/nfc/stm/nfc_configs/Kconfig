choice RFAL_WAKE_UP_MODE
	prompt "Wake-Up Mode configuration"
	default RFAL_WAKE_UP_MODE_RELAXED
	depends on RFAL_FEATURE_WAKEUP_MODE

config RFAL_WAKE_UP_MODE_STRICT
	bool "Strict configuration - less sensitive, more robust"

config RFAL_WAKE_UP_MODE_RELAXED
	bool "Relaxed configuration - more sensitive, less robust"

config RFAL_WAKE_UP_MODE_DEFAULT
	bool "Default RFAL WUM configuration - balanced sensitivity and robustness"

endchoice # RFAL_WAKE_UP_MODE

# Additional wake-up polling behavior
config RFAL_WAKEUP_POLL_BEFORE
    bool "Poll before entering Wake-Up mode"
    depends on RFAL_FEATURE_WAKEUP_MODE
    default y
    help
      Enable polling before entering Wake-Up mode for better device detection.

config RFAL_WAKEUP_NPOLLS
    int "Number of polling cycles before/after Wake-Up mode"
    depends on RFAL_FEATURE_WAKEUP_MODE
    range 1 100
    default 10
    help
      Number of polling cycles to perform before and after Wake-Up mode.
